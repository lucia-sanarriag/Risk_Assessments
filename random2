# Distance
SAT_TO_CORPUS = 150
SAT_TO_HOUSTON = 200
SAT_TO_AUSTIN = 80
MILES_PER_TURN = 50   # miles traveled per turn


def main():
    """Main function."""
    # Welcome banne
    print("Welcome to a'All My Eggses Live in Texas'!")
    name = input("What's your name, traveler? ")

    # Destination menu
    print("\nWhere would you like to go ?")
    print("1. Corpus Christi (BEACH!)")
    print("2. Houston")
    print("3. Austin")

    choice = int(input("Enter your choice (1-3): "))

    # Set destination and distance based on choice
    if choice == 1:
        destination = "Corpus Christi"
        distance = SAT_TO_CORPUS
    elif choice == 2:
        destination = "Houston"
        distance = SAT_TO_HOUSTON
    elif choice == 3:
        destination = "Austin"
        distance = SAT_TO_AUSTIN
    else:
        print("Invalid choice! Defaulting to Austin.")
        destination = "Austin"
        distance = SAT_TO_AUSTIN

    # Initial trip info
    print(f"\nHeading to {destination}!")
    print(f"Distance: {distance} miles")
    print(f"You will travel {MILES_PER_TURN} miles per turn.\n")
    print("=" * 50)
    print("LET THE JOURNEY BEGIN!")
    print("=" * 50 + "\n")

    # Initialize tracking variables
    distance_remaining = distance
    total_miles = 0
    turn = 1

    # While loop: travel until arrival
    while distance_remaining > 0:
        # Display turn info
        print(f"--- Turn {turn} ---")
        print(f"Miles remaining: {distance_remaining}")

        # Travel only remaining mile if less than MILES_PER_TURN
        miles_this_turn = min(MILES_PER_TURN, distance_remaining)
        print(f"Your travel {miles_this_turn} miles...")

        # Update totals
        distance_remaining -= miles_this_turn
        total_miles += miles_this_turn

        # Print miles left after turn (except last turn)
        if distance_remaining > 0:
            print(f"Miles remaining: {distance_remaining}\n")
            turn += 1  # Increment turn only if journey continues
        else:
            print()  # Blank line after last travel

        # Prevent negative mils remaining in final display
        if distance_remaining < 0:
            distance_remaining = 0

    # Trip summary
    print(f"You made it to {destination}!\n")
    print("=" * 50)
    print("TRIP SUMMARY")
    print("=" * 50)
    print(f"Driver: {name}")
    print(f"Destination: {destination}")
    print(f"Distance: {distance} miles")
    print(f"Total Turns: {turn}")
    print(f"Total Miles: {total_miles}")
    print("=" * 50 + "\n")

    # Destination-specific message
    if destination == "Corpus Christi":
        print("CONGRATULATIONS! You reached the beach!")
    elif destination == "Houston":
        print("Galveston is only 50 more miles away")
    elif destination == "Austin":
        print("Austin is nice, but no beach here")

    print("\nThanks for playing!")


if __name__ == '__main__':
    main()
